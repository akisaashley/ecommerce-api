APP_NAME=Ecommerce
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=ecommerce_user
MYSQLPASSWORD=ecommerce_password
MYSQLDATABASE=ecommerce_db

MYSQL_POOL_NAME=sms_pool
MYSQL_POOL_SIZE=5
MYSQL_POOL_RESET_SESSION=true
MYSQL_CONNECT_TIMEOUT=10
MYSQL_MAX_RETRIES=3
MYSQL_RETRY_DELAY_SECONDS=1.5

CORS_ORIGINS=*
AUTO_SEED_ON_STARTUP=true
